## Ignore everything by default; only explicitly allow what we want
/*

## Allow the .gitignore itself so you can selectively track files
!.gitignore

## Explicitly allow frontend and backend directories and their contents
!/frontend/
!/frontend/**

!/backend/
!/backend/**

!/.github/
!/.github/**

## NOTE: root files (README, LICENSE, etc.) remain ignored by default.
## If you want to track a specific root file later, add it explicitly to the index:
##   git add -f README.md
## or update this .gitignore to unignore it (e.g. add `!/README.md`).

# Ignore log and pid files everywhere
*.log
*.pid
*.db
**/*.log
**/*.pid
**/*.db

# Frontend build and dependencies
/frontend/node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/build/

# Backend virtualenv and Python artifacts
/backend/.venv/
/backend/__pycache__/
**/*.pyc

# Local env files
.env
.env.local

!/README.md

## New plots folder (refactored name)
!/plots/
!/plots/**
